# ── SERVER ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── DATABASE (PostgreSQL) ────────────────────────────
# Local:  postgresql://postgres:yourpassword@localhost:5432/ecommerce_db
# Railway/Render: paste the connection string they give you
DATABASE_URL=postgresql://postgres:root@localhost:5432/ecommerce_db

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

